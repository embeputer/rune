# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored. You can paste this file directly into Vercel's
# "Import .env" UI when deploying.
#
# Per-user secrets like the Cursor API key are NOT here — they're configured
# in-app at /account, stored in Supabase, and scoped to each user.

# --- Supabase (required) ---
# Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Project Settings → API Keys → "anon" / "public" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API Keys → "service_role" key
# Server-only — never exposed to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
